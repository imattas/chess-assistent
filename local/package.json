{
  "name": "chess-assistant-local",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop Chess Assistant — embeds chess sites with a Stockfish sidebar. No browser needed.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:linux": "electron-builder --linux AppImage",
    "check": "find . -name '*.js' -not -path './node_modules/*' -not -path './dist/*' -print0 | xargs -0 -n1 node --check"
  },
  "dependencies": {
    "chess.js": "^1.0.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.imattas.chess-assistant-local",
    "productName": "Chess Assistant",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload-webview.js",
      "engine-host.js",
      "fen-replay.js",
      "board-watcher.js",
      "arrow-overlay.js",
      "adapters/**",
      "renderer/**",
      "!**/*.md"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Game",
      "maintainer": "imattas"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.games"
    },
    "win": {
      "target": "nsis"
    }
  }
}
